{
  "name": "testingcharlie",
  "version": "1.0.0",
  "description": "Personal site for Charlie — senior test engineer. Editorial-studio meets CI dashboard.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "build:site": "node scripts/build-github-activity.mjs && node scripts/build-blog-manifest.mjs && tsc && node scripts/build-site.mjs",
    "refresh:github": "node scripts/build-github-activity.mjs",
    "gen:assets": "node scripts/gen-assets.mjs",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "serve": "npm run build:site && npx --yes serve public",
    "dev": "npm run build:site && npx --yes serve public",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run typecheck && npm run coverage && npm run build:site"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Charlie-C-1266/testingcharlie.git"
  },
  "keywords": [
    "portfolio",
    "typescript",
    "test-engineering"
  ],
  "author": "Charlie",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Charlie-C-1266/testingcharlie/issues"
  },
  "homepage": "https://github.com/Charlie-C-1266/testingcharlie#readme",
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^26.0.0",
    "marked": "^18.0.6",
    "serve": "^14.2.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
